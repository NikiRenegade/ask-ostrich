{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "security_public_register": {
        "ClusterId": "security_cluster",
        "Match": { "Path": "/security/register" },
        "Transforms": [{ "PathRemovePrefix": "/security" }]
      },
      "security_public_login": {
        "ClusterId": "security_cluster",
        "Match": { "Path": "/security/login" },
        "Transforms": [{ "PathRemovePrefix": "/security" }]
      },
      "security_public_refresh": {
        "ClusterId": "security_cluster",
        "Match": { "Path": "/security/refresh" },
        "Transforms": [{ "PathRemovePrefix": "/security" }]
      },
      "security_route": {
        "ClusterId": "security_cluster",
        "Match": { "Path": "/security/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/security" }]
      },
      "survey_manage_route": {
        "ClusterId": "survey_manage_cluster",
        "Match": { "Path": "/survey-manage/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/survey-manage" }]
      },
      "survey_response_route": {
        "ClusterId": "survey_response_cluster",
        "Match": { "Path": "/survey-response/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/survey-response" }]
      },
      "ai_assistant_route": {
        "ClusterId": "ai_assistant_cluster",
        "Match": { "Path": "/ai-assistant/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/ai-assistant" }]
      }
    },
    "Clusters": {
      "security_cluster": {
        "Destinations": {
          "security_api": { "Address": "http://ao_security_service:8080/" }
        }
      },
      "survey_manage_cluster": {
        "Destinations": {
          "survey_manage_api": { "Address": "http://ao_survey_manage_service:8080/" }
        }
      },
      "survey_response_cluster": {
        "Destinations": {
          "survey_response_api": { "Address": "http://ao_survey_response_service:8080/" }
        }
      },
      "ai_assistant_cluster": {
        "Destinations": {
          "ai_assistant_api": { "Address": "http://ao_ai_assistant_service:8080/" }
        }
      }
    }
  },
  "Jwt": {
    "Issuer": "askostrich",
    "Audience": "askostrich_frontend",
